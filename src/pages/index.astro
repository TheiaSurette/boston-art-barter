---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getSiteConfig, getHomeContent } from "../lib/content";

const site = await getSiteConfig();
const { data: home, Content } = await getHomeContent();

const ctaLink = site.eventEnded ? home.ctaLinkEnded : home.ctaLink;
const ctaText = site.eventEnded ? home.ctaTextEnded : home.ctaText;

const formattedDate = site.eventDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
  timeZone: "UTC",
});
---

<BaseLayout>
  <section class="hero-section">
    <h1
      class="riso-headline hero-headline"
      data-text={home.headline}
    >
      {home.headline}
    </h1>
    <p class="riso-sub">{home.subheadline}</p>
    <p class="riso-meta">{formattedDate} &mdash; {site.location}</p>
    <a href={ctaLink} class="riso-cta">{ctaText}</a>
  </section>

  <div class="ink-swatches">
    <div class="ink-swatch"></div>
    <div class="ink-swatch"></div>
    <div class="ink-swatch"></div>
    <div class="ink-swatch"></div>
    <div class="ink-swatch"></div>
  </div>

  <div class="content-block">
    <div class="star-stamp star-stamp-1"></div>
    <div class="star-stamp star-stamp-2"></div>
    <div class="star-stamp star-stamp-3"></div>
    <div class="star-stamp star-stamp-4"></div>
    <div class="content-body">
      <Content />
    </div>
  </div>
</BaseLayout>
